{{> head}}
{{> header}}
<main>
  <a class="back-link" href="/organiser">← Back to dashboard</a>
  <h1>{{course.title}} — Class List</h1>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Type</th>
          <th>Status</th>
          <th>Booked At</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#bookings}}
        <tr>
          <td>{{userName}}</td>
          <td>{{type}}</td>
          <td>{{status}}</td>
          <td>{{createdAt}}</td>
          <td>
            {{^isCancelled}}
            <form method="POST" action="/organiser/bookings/{{_id}}/cancel">
              <button type="submit">Cancel</button>
            </form>
            {{/isCancelled}}
          </td>
        </tr>
        {{/bookings}}
        {{^bookings}}
        <tr><td colspan="4">No bookings yet.</td></tr>
        {{/bookings}}
      </tbody>
    </table>
  </div>
</main>
{{> footer}}
