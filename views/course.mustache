{{> head}}
{{> header}}
<main>

  <a class="back-link" href="/courses">← Back to courses</a>

  <div class="course-top">

    {{! course info }}
    <div>
      <h1 style="margin-bottom:1rem">{{course.title}}</h1>

      <div class="course-meta">
        <span class="badge">{{course.level}}</span>
        <span class="badge">{{course.type}}</span>
        {{#course.allowDropIn}}<span class="badge" style="color:var(--primary);border-color:var(--primary)">Drop-ins welcome</span>{{/course.allowDropIn}}
      </div>

      <p class="muted" style="margin-bottom:1.25rem">{{course.startDate}} – {{course.endDate}}</p>
      <p style="max-width:560px">{{course.description}}</p>
    </div>

    {{! booking card }}
    <div class="booking-card">
      <h2>Book this course</h2>
      <div class="meta-row"><span>Sessions</span><span>{{course.sessionsCount}}</span></div>
      <div class="meta-row"><span>Dates</span><span>{{course.startDate}} – {{course.endDate}}</span></div>
      <div class="meta-row"><span>Drop-in</span><span>{{#course.allowDropIn}}Yes{{/course.allowDropIn}}{{^course.allowDropIn}}No{{/course.allowDropIn}}</span></div>

      {{#course.alreadyBooked}}
        {{#course.isWaitlisted}}
        <div class="booked-notice waitlisted">
          <span class="booked-icon">&#8987;</span>
          <div>
            <strong>You're on the waitlist</strong>
            <p>We'll notify you if a space opens up.</p>
          </div>
        </div>
        {{/course.isWaitlisted}}
        {{^course.isWaitlisted}}
        <div class="booked-notice confirmed">
          <span class="booked-icon">&#10003;</span>
          <div>
            <strong>You're booked in</strong>
            <p>See you on the mat!</p>
          </div>
        </div>
        {{/course.isWaitlisted}}
      {{/course.alreadyBooked}}
      {{^course.alreadyBooked}}
        {{#user}}
        <form action="/courses/{{course.id}}/book" method="post">
          <button class="btn" type="submit">Book full course</button>
        </form>
        {{/user}}
        {{^user}}
        <a class="btn" href="/login" style="width:100%;justify-content:center">Log in to book</a>
        {{/user}}
      {{/course.alreadyBooked}}
    </div>

  </div>

  {{! sessions list }}
  <h2 style="margin-bottom:1rem">Session Schedule</h2>
  <div class="table-wrap shrink">
  <table>
    <thead>
      <tr>
        <th>Date &amp; time</th>
        <th>Capacity</th>
        <th>Booked</th>
        <th>Remaining</th>
        {{#course.allowDropIn}}<th>Drop into session</th>{{/course.allowDropIn}}
      </tr>
    </thead>
    <tbody>
      {{#sessions}}
      <tr>
        <td>{{start}}</td>
        <td>{{capacity}}</td>
        <td>{{booked}}</td>
        <td>
          {{#isFull}}<span class="badge" style="color:#a03030;border-color:#fecaca;background:#fff5f5">Full</span>{{/isFull}}
          {{^isFull}}<strong>{{remaining}}</strong>{{/isFull}}
        </td>
        {{#allowDropIn}}
        <td>
          {{#alreadyBooked}}
            <span class="session-booked-badge">&#10003; Booked</span>
          {{/alreadyBooked}}
          {{^alreadyBooked}}
            {{#user}}
            <form action="/sessions/{{id}}/book" method="post" style="margin:0;background:none;border:none;padding:0;box-shadow:none;border-radius:0;">
              <button class="btn" type="submit"{{#isFull}} disabled style="opacity:0.45;cursor:not-allowed"{{/isFull}}>{{#isFull}}Full{{/isFull}}{{^isFull}}Book drop-in{{/isFull}}</button>
            </form>
            {{/user}}
            {{^user}}<a href="/login" class="muted" style="font-size:0.875rem">Log in to book</a>{{/user}}
          {{/alreadyBooked}}
        </td>
        {{/allowDropIn}}
      </tr>
      {{/sessions}}
      {{^sessions}}
      <tr><td colspan="5" class="muted">No sessions scheduled yet.</td></tr>
      {{/sessions}}
    </tbody>
  </table>
  </div>

</main>
{{> footer}}
