{{> head}}
{{> header}}

<div class="hero-wrap">
<section class="hero">
  <h1>Find your flow</h1>
  <p>Yoga classes for every level — from first-timers to seasoned practitioners. Book a full course or drop in to a single session.</p>
  <a class="btn-hero" href="/courses">Browse all courses →</a>
</section>
</div>

<div class="course-strip-section">
  <div class="course-strip-header">
    <h2>Upcoming courses</h2>
    <a href="/courses">View all →</a>
  </div>

  <div class="course-strip">
    {{#courses}}
    <article class="card">
      <h3><a href="/courses/{{id}}">{{title}}</a></h3>
      <p class="muted" style="font-size:0.8rem">{{level}} · {{type}}</p>
      <p class="muted" style="font-size:0.8rem">{{startDate}} – {{endDate}}</p>
      <p style="font-size:0.875rem;flex:1">{{description}}</p>
      <a class="btn" href="/courses/{{id}}">View &amp; Book</a>
    </article>
    {{/courses}}
    {{^courses}}
    <p class="muted">No courses available yet.</p>
    {{/courses}}
  </div>
</div>

{{> footer}}
